[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.6
reloadable = true

[libraries]
windows.debug.x86_64 = "res://build/bin/reia_backend.debug.dll"
windows.release.x86_64 = "res://build/bin/reia_backend.release.dll"
linux.debug.x86_64 = "res://build/bin/libreia_backend.debug.so"
linux.release.x86_64 = "res://build/bin/libreia_backend.release.so"
macos.debug = "res://build/bin/libreia_backend.debug.dylib"
macos.release = "res://build/bin/libreia_backend.release.dylib"
